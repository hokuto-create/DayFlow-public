# ============================================================
# DayFlow 課金＋AI機能の環境変数（Supabase Edge Functions の secrets）
#
# 設定方法:
#   cp .env.example .env  →  値を埋める  →  supabase secrets set --env-file .env
#
# ※ SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY は
#   Edge Functions に自動で渡されるため、ここでの設定は不要です。
# ※ .env は絶対にコミットしないでください。
# ============================================================

# --- Stripe ---
# ダッシュボード > 開発者 > APIキー（テストは sk_test_、本番は sk_live_）
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook エンドポイント登録時に発行される署名シークレット
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe で作成した Price の ID（README の手順1参照）
# スタンダード ¥600/月
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
# スタンダード ¥6,000/年
STRIPE_PRICE_STANDARD_YEARLY=price_xxx
# プレミアム ¥1,000/月
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
# プレミアム ¥10,000/年
STRIPE_PRICE_PREMIUM_YEARLY=price_xxx

# --- Anthropic（AI目次取り込み）---
ANTHROPIC_API_KEY=sk-ant-xxx
# 使用モデル。精度優先のデフォルトは claude-opus-4-8。
# コストを抑えたい場合のみ claude-haiku-4-5（$1/$5 per MTok）に切り替え可。
AI_TOC_MODEL=claude-opus-4-8
# 1ユーザーあたりの日次実行回数上限（乱用対策）
AI_DAILY_LIMIT=20

# --- CORS / リダイレクト先の制限（任意）---
# 未設定は "*"（全オリジン許可）。本番ではアプリのオリジンに絞ることを推奨。
# 例: ALLOWED_ORIGIN=https://your-app.example.com
ALLOWED_ORIGIN=*
